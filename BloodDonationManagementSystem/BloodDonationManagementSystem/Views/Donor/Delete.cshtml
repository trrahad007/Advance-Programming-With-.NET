@{
}
@model BloodDonationManagementSystem.EF.Tables.Donor
<h2>Are you sure to delete?</h2>
<br />
<br />
<p>Id: <strong>@Model.DonorId</strong></p>
<p>Full Name: <strong>@Model.FullName</strong></p>
<p>Blood Group: <strong>@Model.BloodGroup</strong></p>
<p>Contact No: <strong>@Model.ContactNo</strong></p>
<p>City: <strong>@Model.City</strong></p>
<p>Last Donation Date: <strong>@Model.LastDonationDate</strong></p>
<form method="post">
    <input type="hidden" name="id" value="@Model.DonorId" />
    <input type="submit" value="Yes" name="Dcsn" class="btn btn-danger" />
    <input type="submit" value="No" name="Dcsn" class="btn btn-success" />
</form>
